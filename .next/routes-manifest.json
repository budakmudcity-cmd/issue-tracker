{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/projects/[projectId]",
      "regex": "^/projects/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId"
      },
      "namedRegex": "^/projects/(?<nxtPprojectId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/projects/[projectId]/issues/new",
      "regex": "^/projects/([^/]+?)/issues/new(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId"
      },
      "namedRegex": "^/projects/(?<nxtPprojectId>[^/]+?)/issues/new(?:/)?$"
    },
    {
      "page": "/projects/[projectId]/issues/[issueId]",
      "regex": "^/projects/([^/]+?)/issues/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId",
        "nxtPissueId": "nxtPissueId"
      },
      "namedRegex": "^/projects/(?<nxtPprojectId>[^/]+?)/issues/(?<nxtPissueId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/projects/[projectId]/issues/[issueId]/edit",
      "regex": "^/projects/([^/]+?)/issues/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId",
        "nxtPissueId": "nxtPissueId"
      },
      "namedRegex": "^/projects/(?<nxtPprojectId>[^/]+?)/issues/(?<nxtPissueId>[^/]+?)/edit(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
      "regex": "^/admin/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dashboard(?:/)?$"
    },
    {
      "page": "/admin/settings",
      "regex": "^/admin/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/settings(?:/)?$"
    },
    {
      "page": "/auth/login",
      "regex": "^/auth/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/login(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}